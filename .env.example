# App URL (used for redirects, checkout return URLs, proxy fallback)
# In production, set this to your deployed frontend origin (https://...), not the API host.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Plutus API — must include /v1 (Nest URI versioning)
# Used in the browser (SWR, login, etc.); prefer this over BACKEND_API_URL alone.
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001/v1

# Optional: server-side fallback if NEXT_PUBLIC_* is unset
BACKEND_API_URL=http://localhost:3001/v1

# --- Production example (set these in your host’s env UI before `next build`) ---
# NEXT_PUBLIC_APP_URL=https://your-frontend.example.com
# NEXT_PUBLIC_BACKEND_API_URL=https://plutus-api-462298977190.us-central1.run.app/v1
# BACKEND_API_URL=https://plutus-api-462298977190.us-central1.run.app/v1

# Optional legacy API key header (Plutus JWT is primary)
BACKEND_API_KEY=

# Stripe (boilerplate checkout / webhooks)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

NODE_ENV=development
